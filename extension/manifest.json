{
  "manifest_version": 3,
  "name": "PhantomWall",
  "version": "1.0.0",
  "description": "Distributed browser privacy and tracker defense for Chrome.",
  "minimum_chrome_version": "116",
  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "PhantomWall",
    "default_popup": "popup.html"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "tracker-rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
